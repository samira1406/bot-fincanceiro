# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# JID do grupo principal (obrigatório)
GRUPO_PERMITIDO=120363408102479565@g.us

# Grupos adicionais, separados por vírgula (opcional — suporte multi-grupo)
# GRUPOS_EXTRAS=220363408102479565@g.us,320363408102479565@g.us

# ─── Palavras que classificam uma mensagem como ENTRADA ───────────────────────
PALAVRAS_ENTRADA=salario,extra,freela,bonus,pix,aluguel,dividendo,reembolso

# ─── Regras financeiras ───────────────────────────────────────────────────────
CAIXINHA_PERCENTUAL=30
VALOR_MAXIMO=100000

# ─── Comportamento ────────────────────────────────────────────────────────────
TIMEOUT_ESTADO_MINUTOS=10
HORA_LEMBRETE_MENSAL=20

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MSG_POR_MINUTO=15

# ─── Painel web ───────────────────────────────────────────────────────────────
PAINEL_PORTA=3000
PAINEL_TOKEN=troque-por-um-token-secreto-forte

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_MANTER_DIAS=7

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production
