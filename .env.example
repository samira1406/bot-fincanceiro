# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# JID legado para rotinas automáticas
GRUPO_PERMITIDO=120363000000000000@g.us

# Configuração legada
# GRUPOS_EXTRAS=220363000000000000@g.us,320363000000000000@g.us

# ─── Palavras que classificam uma mensagem como ENTRADA ───────────────────────
PALAVRAS_ENTRADA=salario,extra,freela,bonus,pix,aluguel,dividendo,reembolso

# ─── Regras financeiras ───────────────────────────────────────────────────────
CAIXINHA_PERCENTUAL=30
VALOR_MAXIMO=100000

# ─── Comportamento ────────────────────────────────────────────────────────────
TIMEOUT_ESTADO_MINUTOS=10
HORA_LEMBRETE_MENSAL=20

# Modo seguro recomendado para beta e WhatsApp Web
WHATSAPP_INTERACTIVE_ENABLED=false
WHATSAPP_MENU_MODE=text

# Modos disponíveis:
# text = sempre envia somente texto
# interactive = tenta lista experimental e envia instrução "menu texto"
# auto = tenta lista experimental e também envia o menu textual completo

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MSG_POR_MINUTO=15

# ─── Beta fechado ─────────────────────────────────────────────────────────────
# false ou ausente = qualquer pessoa pode usar no privado
# true = apenas números listados em BETA_ALLOWED_NUMBERS podem usar
# false = bloqueado é ignorado sem resposta automática
# Use DDI + DDD. Exemplo: 5515999999999
BETA_MODE=false
BETA_BLOCKED_REPLY=false
BETA_DEBUG=false
BETA_DEBUG_SHOW_RAW=false
BETA_ALLOWED_NUMBERS=5511000000000,5511000000001
BETA_ALLOWED_JIDS=1234567890@lid,0987654321@lid
BETA_ALLOWED_GROUPS=120363000000000000@g.us
BETA_GROUP_REQUIRE_AUTHORIZED_PARTICIPANT=true

# ─── Painel web ───────────────────────────────────────────────────────────────
PORT=3000
PAINEL_PORTA=3000
PAINEL_TOKEN=troque-por-um-token-secreto-forte
DASHBOARD_TOKEN=troque-este-token

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_MANTER_DIAS=7
BACKUP_DIR=./database/backups

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_PATH=./database/financas.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production
