# =============================================================================
# BOT FINANCAS - CONFIGURACAO DE EXEMPLO
# Copie para .env e use somente valores locais. Nunca versione o .env real.
# =============================================================================

# --- Ambiente ---------------------------------------------------------------
# development para uso local; production quando gerenciado por PM2/VPS.
NODE_ENV=production

# --- WhatsApp ---------------------------------------------------------------
# JID legado usado por rotinas automaticas. Substitua apenas no .env local.
GRUPO_PERMITIDO=120363000000000000@g.us

# Grupos legados adicionais, separados por virgula.
GRUPOS_EXTRAS=

# --- Regras financeiras -----------------------------------------------------
# Termos locais que ajudam a reconhecer entradas.
PALAVRAS_ENTRADA=salario,extra,freela,bonus,pix,aluguel,dividendo,reembolso

# Percentual sugerido para a caixinha.
CAIXINHA_PERCENTUAL=30

# Maior valor permitido por lancamento, em reais.
VALOR_MAXIMO=100000

# --- Comportamento ----------------------------------------------------------
# Tempo para expirar fluxos pendentes.
TIMEOUT_ESTADO_MINUTOS=10

# Hora local do lembrete mensal.
HORA_LEMBRETE_MENSAL=20

# Limite de mensagens por usuario a cada minuto.
RATE_LIMIT_MSG_POR_MINUTO=15

# --- Menus do WhatsApp ------------------------------------------------------
# O modo textual e o padrao mais estavel para o beta.
WHATSAPP_INTERACTIVE_ENABLED=false
WHATSAPP_MENU_MODE=text

# Modos: text, interactive ou auto.

# --- Beta fechado -----------------------------------------------------------
# false permite conversas privadas; use true no beta controlado.
BETA_MODE=false

# false mantem contatos bloqueados em silencio.
BETA_BLOCKED_REPLY=false

# Logs mascarados para diagnostico da whitelist.
BETA_DEBUG=false

# Mantenha false. true pode mostrar identificadores crus somente no terminal.
BETA_DEBUG_SHOW_RAW=false

# Exemplos ficticios. Use DDI + DDD no .env local.
BETA_ALLOWED_NUMBERS=5511000000000,5511000000001

# JIDs opcionais, inclusive @lid, separados por virgula.
BETA_ALLOWED_JIDS=1234567890@lid,0987654321@lid

# Grupos autorizados no beta.
BETA_ALLOWED_GROUPS=120363000000000000@g.us

# Exige que o participante do grupo tambem esteja autorizado.
BETA_GROUP_REQUIRE_AUTHORIZED_PARTICIPANT=true

# --- IA interpretadora opcional --------------------------------------------
# A IA somente devolve JSON. O parser local continua prioritario.
AI_INTERPRETER_ENABLED=false

# Providers aceitos: openai ou gemini.
AI_PROVIDER=openai

# --- OpenAI -----------------------------------------------------------------
# Modelo e chave ficam vazios ate o provider ser ativado localmente.
AI_MODEL=
AI_API_KEY=

# --- Gemini -----------------------------------------------------------------
# Chave local e modelo usado quando AI_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1200

# --- Validacao e logs da IA -------------------------------------------------
# Limites de confianca entre 0 e 1.
AI_MIN_CONFIDENCE=0.85
AI_CONFIRMATION_CONFIDENCE=0.60

# Timeout em milissegundos.
AI_TIMEOUT_MS=8000

# Logs tecnicos sanitizados. Mantenha o conteudo bruto desligado.
AI_LOG_ENABLED=false
AI_LOG_RAW=false

# --- Painel administrativo --------------------------------------------------
# PORT e DASHBOARD_TOKEN sao aliases uteis em plataformas de deploy.
PORT=3000
PAINEL_PORTA=3000

# Troque ambos no .env local por segredo longo e exclusivo.
PAINEL_TOKEN=troque-por-um-token-secreto-forte
DASHBOARD_TOKEN=troque-este-token

# --- Banco de dados ---------------------------------------------------------
# O banco real deve permanecer fora do Git.
DATABASE_PATH=./database/financas.db

# --- Backup -----------------------------------------------------------------
# Diretorio local e dias de retencao.
BACKUP_DIR=./database/backups
BACKUP_MANTER_DIAS=7

# --- Logs -------------------------------------------------------------------
# Niveis comuns: silent, error, warn, info, debug.
LOG_LEVEL=info
